#include<iostream>

using namespace std;

//encapsulation
class Marvellous
{
    //access specifier
    public:
    int No1, No2;    //characteristics

    void fun()        //behaviour
    {
        cout<<"inside fun\n";
    }
    void gun()       //behaviour
    {
        cout<<"inside gun\n";
    }
};

int main()
{


    //object creation (instance)
    Marvellous mobj1;
    Marvellous mobj2;

    cout<<sizeof(mobj1)<<"\n";   //8

    cout<<mobj1.No1<<"\n";  //Garbage
    mobj1.fun();
    mobj2.fun();
    mobj1.gun();
    return 0;

}
