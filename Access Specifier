#include<iostream>
using namespace std;

class Demo
{
    public: int i;
    private: int j;
    protected: int k;

    public:
        Demo()
        {
            i = 0;
            j = 0;
            k = 0;
        }

        void Diaplay()
        {
            cout<<"value of i :"<<i<<"\n";  //Allowed
            cout<<"value of j :"<<j<<"\n";  //Allowed
            cout<<"value of i :"<<k<<"\n";  //Allowed
        }
    

};

int main()
{
    Demo dobj;

    dobj.Diaplay();

    cout<<"value of i:"<<dobj.i<<"\n";  //Allowed
    cout<<"value of j:"<<dobj.j<<"\n";  //Not Allowed
    cout<<"value of k:"<<dobj.k<<"\n";  //Not Allowed

    return 0;
}
